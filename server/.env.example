# Set these in the Railway "backend" service → Variables tab.

# Port Railway assigns (Railway sets PORT automatically — leave unset to use it,
# or it defaults to 3001 if not provided).
PORT=3001

# Comma-separated list of allowed frontend origins for CORS.
# Set this to your deployed frontend's Railway URL.
ALLOWED_ORIGINS=https://your-frontend.up.railway.app,http://localhost:5173
